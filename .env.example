# ============================================================
# Matha Furniture - Environment Variables
# Copy this file to ".env.local" and fill in your values.
# The site works with built-in sample data even if these are blank.
# ============================================================

# --- Supabase (database, storage, admin auth) ---
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key - SERVER ONLY. Never expose to the browser.
# Used by admin API routes for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=

# Name of the Supabase Storage bucket for product/gallery images.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=matha-media

# --- Business contact (used as fallback defaults) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
NEXT_PUBLIC_SITE_URL=http://localhost:3000
